{
  "name": "product-label-generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "產品標籤自動化生成工具 (5cm × 3cm)，支援日本超市風格與台灣 NT$ 風格切換。",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:run": "vitest run",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
